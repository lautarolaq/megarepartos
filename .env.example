# Megarepartos — variables de entorno
# Copiar a `.env` (gitignored) y completar valores locales.

# ---- App ----
APP_ENV=local                # local | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ---- Database ----
# Local: docker-compose levanta Postgres en localhost:5432.
# Prod: Neon connection string (postgresql+asyncpg://...).
DATABASE_URL=postgresql+asyncpg://megarepartos:megarepartos@localhost:5433/megarepartos

# Alias usado en deploy. Si está seteado, gana sobre DATABASE_URL.
# NEON_DATABASE_URL=

# ---- Auth ----
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=cambiame-en-local-y-en-secret-manager-en-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=14

# Google OAuth (se completa en TASK-001).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8000/api/auth/google/callback

# ---- Frontend ----
# Vite expone estas con prefijo VITE_.
VITE_API_BASE_URL=http://localhost:8000
VITE_GOOGLE_OAUTH_CLIENT_ID=

# ---- Servicios externos ----
# Geocoding de direcciones de clientes. Si está vacío, geocoding queda
# deshabilitado y los clientes se crean sin coordenadas (fail-soft).
GOOGLE_MAPS_API_KEY=

# (TASKs posteriores)
# MERCADOPAGO_ACCESS_TOKEN=
# GCS_BUCKET_BACKUPS=
